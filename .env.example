# Copy to `.env` in this directory (do not commit `.env`). GenOS / Intuit IAM for project-air.
# See genai_tax_core.py: _get_genos_env(), _genos_metadata()


# GenOS / Intuit IAM — loaded by genai_tax_core (do not commit). All GenOS IDs must come from here.
GENOS_ENV=e2e
GENOS_EXPERIENCE_ID=75be454b-adb9-4bb3-af7f-3275e04908c8
GENOS_ASSET_ALIAS=Intuit.incometax.triage.agenticita
GENOS_MODEL_ID=gpt-5.4-2026-03-05

# Chat UI only: ask_llm_chat() uses POST .../v3/lt/{GENOS_MODEL_ID}/responses (tax/insights use chat/completions).
# Optional tools JSON for responses, e.g. [{"type":"web_search_preview"}]
# GENOS_RESPONSES_TOOLS=[{"type":"web_search_preview"}]
# Optional: only if the gateway expects these (defaults omit them): GENOS_RESPONSES_SEND_MAX_TOKENS=1  GENOS_RESPONSES_SEND_TEMPERATURE=1
# Set to 0 to silence [GenOS] request lines on stderr: DEBUG_GENOS_CALLS=0

# --- Intuit app + IAM (passed to genosclient metadata; headers use Intuit_IAM_Authentication internally) ---
INTUIT_APP_ID=Intuit.incometax.triage.agenticita
INTUIT_APP_SECRET=
INTUIT_AUTH_ID=
INTUIT_IAM_TICKET=



# DEBUG_TAX_CALC=1

# Optional: SQLite path for Save workspace / Load workspace (default: ./data/workspace.sqlite)
# WORKSPACE_DB_PATH=/path/to/workspace.sqlite
