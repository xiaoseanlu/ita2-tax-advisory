{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Strategy Evaluation Input Summary",
  "description": "Input data passed for ITA strategy evaluation. Use together with output summary (form_1040_calculated_lines) for MAGI, AGI, taxable_income, and other determinations. Together they define what to pass for strategy insights.",
  "usage": "Pass strategy_input_summary + form_1040_calculated_lines to evaluate applicable strategies.",

  "strategy_input_summary": {
    "type": "object",
    "description": "Extracted/scenario inputs for strategy matching. Aligns with tax_situation; streamlined for strategy evaluation.",
    "properties": {
      "filing_info": {
        "type": "object",
        "properties": {
          "tax_year": { "type": "integer", "description": "Tax year (e.g. 2024, 2025)." },
          "filing_status": { "type": "string", "description": "Single, Married Filing Jointly, Married Filing Separately, Head of Household, Qualifying Surviving Spouse." },
          "primary_resident_state": { "type": "string", "description": "State of primary residence." }
        }
      },
      "people": {
        "type": "object",
        "description": "Taxpayer, spouse, dependents. Age/DOB used for catch-up, IRA QCD, CTC.",
        "properties": {
          "taxpayer": {
            "type": "object",
            "properties": {
              "age_65_or_older": { "type": "boolean", "description": "For 401k catch-up, standard deduction bump." },
              "age_70_5_or_older": { "type": "boolean", "description": "For IRA QCD." }
            }
          },
          "spouse": {
            "type": ["object", "null"],
            "properties": {
              "age_65_or_older": { "type": "boolean" },
              "age_70_5_or_older": { "type": "boolean" }
            }
          },
          "dependents": {
            "type": "array",
            "description": "Needed for Child Tax Credit, Hiring Children.",
            "items": {
              "type": "object",
              "properties": {
                "qualifying_child_under_17": { "type": "boolean" },
                "claimed": { "type": "boolean" }
              }
            }
          }
        }
      },
      "income": {
        "type": "object",
        "description": "Core income for strategy evaluation. TP/Spouse split for wages.",
        "properties": {
          "wages": {
            "type": "object",
            "description": "W-2 wages. TP/Spouse split critical for Hiring Spouse, 401k.",
            "properties": {
              "taxpayer": { "type": "number", "description": "Taxpayer W-2 wages." },
              "spouse": { "type": "number", "description": "Spouse W-2 wages." },
              "federal_withholding": { "type": "number", "description": "Total federal withholding (optional)." }
            }
          },
          "schedule_c_net": {
            "type": "number",
            "description": "Net Schedule C profit/loss. For S-Corp, QBI, SEP, Solo 401k, Hiring Spouse, Home Office, MERP."
          },
          "schedule_e_rental": {
            "type": "number",
            "description": "Net Schedule E rental income/loss. For QBI, Cost Seg, Augusta Rule (if rental_days)."
          },
          "schedule_e_pass_through": {
            "type": "object",
            "description": "K-1 from S-Corps, Partnerships. TP/Spouse split if meaningful.",
            "properties": {
              "taxpayer": { "type": "number" },
              "spouse": { "type": "number" }
            }
          },
          "short_term_capital_gain_loss": { "type": "number", "description": "For loss harvesting, capital gain timing." },
          "long_term_capital_gains": { "type": "number", "description": "For gain timing, loss harvesting, charitable securities." },
          "wash_sale_disallowed": { "type": "number", "description": "For loss harvesting context." },
          "ordinary_dividends": { "type": "number" },
          "qualified_dividends": { "type": "number" },
          "taxable_interest": { "type": "number" },
          "taxable_pensions": { "type": "number" },
          "other_income": { "type": "number" }
        }
      },
      "depreciable_assets": {
        "type": "array",
        "description": "For Section 179, Bonus Depreciation.",
        "items": {
          "type": "object",
          "properties": {
            "basis": { "type": "number" },
            "recovery_period_years": { "type": "number" },
            "placed_in_service_year": { "type": "integer" }
          }
        }
      },
      "itemized_deductions": {
        "type": "object",
        "description": "For Bunching strategy.",
        "properties": {
          "state_and_local_taxes": { "type": "number" },
          "state_and_local_taxes_paid": { "type": "number" },
          "mortgage_interest": { "type": "number" },
          "charitable_contributions": { "type": "number" }
        }
      },
      "rental_personal_residence": {
        "type": "object",
        "description": "For Augusta Rule (14-day rental).",
        "properties": {
          "days_rented": { "type": "integer" },
          "rental_income": { "type": "number" }
        }
      },
      "real_estate_cost": {
        "type": "number",
        "description": "Commercial/rental property cost for Cost Segregation ($500K+)."
      }
    }
  },

  "output_summary": {
    "type": "object",
    "description": "Calculated 1040-style output (form_1040_calculated_lines from tax-situation-and-1040-schema). Used with input for MAGI, AGI, taxable income determinations.",
    "properties": {
      "adjusted_gross_income": { "type": "number" },
      "magi": { "type": "number", "description": "For NIIT, CTC phaseout, IRA phaseouts." },
      "taxable_income": { "type": "number", "description": "For QBI phase-out, bracket management." },
      "schedule_c_net_profit_or_loss": { "type": "number" },
      "standard_or_itemized_deduction_used": { "type": "string" },
      "deduction_amount": { "type": "number" },
      "qbi_deduction": { "type": "number" },
      "ordinary_income_portion": { "type": "number" },
      "preferential_income_portion": { "type": "number" },
      "net_investment_income": { "type": "number" },
      "regular_income_tax": { "type": "number" },
      "net_investment_income_tax": { "type": "number" },
      "total_tax_liability": { "type": "number" },
      "total_payments": { "type": "number" },
      "amount_owed_or_refund": { "type": "number" }
    }
  },

  "strategies": [
    { "strategy_id": "ita_001", "title": "Real Estate Professional Status Election", "category": "entity", "covered_by": "none", "inputs_required": ["re_hours_750_plus", "re_percent_50_plus"], "outputs_used": [] },
    { "strategy_id": "ita_002", "title": "S-Corp Election", "category": "entity", "covered_by": "full", "inputs_required": ["income.schedule_c_net"], "outputs_used": [], "key_conditions": ["Schedule C net $60K+ profit", "domestic corp/LLC", "Exclude if Schedule C net ≤ 0"] },
    { "strategy_id": "ita_003", "title": "S-Corp Reasonable Comp", "category": "entity", "covered_by": "partial", "inputs_required": ["income.schedule_e_pass_through", "income.wages"], "outputs_used": [] },
    { "strategy_id": "ita_004", "title": "Pass-Through Entity Selection", "category": "entity", "covered_by": "full", "inputs_required": ["income.schedule_c_net", "income.schedule_e_pass_through", "income.wages"], "outputs_used": [], "key_conditions": ["Pass-through net profit to compare", "Exclude if sole Schedule C is a loss-only pattern"] },
    { "strategy_id": "ita_005", "title": "HSA + FSA Coordination", "category": "individual", "covered_by": "none", "inputs_required": ["health_plan_type"], "outputs_used": [] },
    { "strategy_id": "ita_006", "title": "Employee Accountable Reimbursement", "category": "business", "covered_by": "partial", "inputs_required": ["income.wages"], "outputs_used": [] },
    { "strategy_id": "ita_007", "title": "Employer Accountable Plan", "category": "business", "covered_by": "partial", "inputs_required": ["income.schedule_c_net", "income.schedule_e_pass_through"], "outputs_used": [] },
    { "strategy_id": "ita_008", "title": "Bunching Itemized", "category": "individual", "covered_by": "none", "inputs_required": ["itemized_deductions", "output.deduction_amount"], "outputs_used": ["deduction_amount"] },
    { "strategy_id": "ita_009", "title": "Home Office Deduction", "category": "business", "covered_by": "full", "inputs_required": ["income.schedule_c_net"], "outputs_used": [] },
    { "strategy_id": "ita_010", "title": "Business Travel Optimization", "category": "business", "covered_by": "partial", "inputs_required": ["income.schedule_c_net"], "outputs_used": [] },
    { "strategy_id": "ita_011", "title": "Student Loan Repayment", "category": "individual", "covered_by": "partial", "inputs_required": ["income.wages"], "outputs_used": [] },
    { "strategy_id": "ita_012", "title": "Dependent Care FSA", "category": "individual", "covered_by": "partial", "inputs_required": ["income.wages"], "outputs_used": [] },
    { "strategy_id": "ita_013", "title": "Health Care FSA", "category": "individual", "covered_by": "partial", "inputs_required": ["income.wages"], "outputs_used": [] },
    { "strategy_id": "ita_014", "title": "Pre-Tax Health Premiums", "category": "individual", "covered_by": "partial", "inputs_required": ["income.wages", "income.schedule_c_net"], "outputs_used": [] },
    { "strategy_id": "ita_015", "title": "HSA Maximization", "category": "individual", "covered_by": "none", "inputs_required": ["health_plan_type"], "outputs_used": [] },
    { "strategy_id": "ita_016", "title": "MERP", "category": "business", "covered_by": "full", "inputs_required": ["income.schedule_c_net", "income.schedule_e_pass_through"], "outputs_used": [], "key_conditions": ["Small employer with profit to fund reimbursements", "Exclude if Schedule C net ≤ 0 unless other business profit"] },
    { "strategy_id": "ita_017", "title": "§1031 Like-Kind Exchange", "category": "business", "covered_by": "partial", "inputs_required": ["income.schedule_e_rental"], "outputs_used": [] },
    { "strategy_id": "ita_018", "title": "Augusta Rule (14-Day Rental)", "category": "business", "covered_by": "none", "inputs_required": ["rental_personal_residence.days_rented"], "outputs_used": [] },
    { "strategy_id": "ita_019", "title": "Capital Gain Timing", "category": "individual", "covered_by": "none", "inputs_required": ["income.long_term_capital_gains", "income.short_term_capital_gain_loss"], "outputs_used": ["taxable_income"] },
    { "strategy_id": "ita_020", "title": "Hiring Children", "category": "business", "covered_by": "partial", "inputs_required": ["income.schedule_c_net", "people.dependents"], "outputs_used": [], "key_conditions": ["Legitimate services", "Exclude if Schedule C net ≤ 0"] },
    { "strategy_id": "ita_021", "title": "Hiring Spouse", "category": "business", "covered_by": "full", "inputs_required": ["income.schedule_c_net", "income.wages", "people.spouse"], "outputs_used": [], "key_conditions": ["Bona fide services", "Exclude if Schedule C net ≤ 0 unless other facts justify"] },
    { "strategy_id": "ita_022", "title": "Tax Loss Harvesting (LTCG)", "category": "individual", "covered_by": "none", "inputs_required": ["income.long_term_capital_gains", "income.short_term_capital_gain_loss"], "outputs_used": [] },
    { "strategy_id": "ita_023", "title": "Tax Loss Harvesting (STCG)", "category": "individual", "covered_by": "none", "inputs_required": ["income.short_term_capital_gain_loss"], "outputs_used": [] },
    { "strategy_id": "ita_024", "title": "Installment Sale", "category": "business", "covered_by": "none", "inputs_required": ["income.long_term_capital_gains"], "outputs_used": [] },
    { "strategy_id": "ita_025", "title": "Bonus Depreciation", "category": "business", "covered_by": "none", "inputs_required": ["depreciable_assets"], "outputs_used": [], "key_conditions": ["Qualifying property placed in service", "May still apply if Schedule C shows a loss (not same as S-Corp/QBI)"] },
    { "strategy_id": "ita_026", "title": "Section 179", "category": "business", "covered_by": "none", "inputs_required": ["depreciable_assets"], "outputs_used": ["taxable_income"], "key_conditions": ["Qualifying property placed in service", "May still apply if Schedule C shows a loss (not same as S-Corp/QBI)"] },
    { "strategy_id": "ita_027", "title": "Cost Segregation", "category": "business", "covered_by": "partial", "inputs_required": ["income.schedule_e_rental", "real_estate_cost"], "outputs_used": [] },
    { "strategy_id": "ita_028", "title": "QBI Deduction (§199A)", "category": "business", "covered_by": "full", "inputs_required": ["income.schedule_c_net", "income.schedule_e_rental", "income.schedule_e_pass_through"], "outputs_used": ["taxable_income"], "key_conditions": ["Positive QBI from at least one trade/business", "Exclude if Schedule C net ≤ 0 and no other positive QBI"] },
    { "strategy_id": "ita_029", "title": "QBI Phase-Out Planning", "category": "business", "covered_by": "full", "inputs_required": ["income.schedule_c_net", "income.schedule_e_rental", "income.schedule_e_pass_through"], "outputs_used": ["taxable_income"], "key_conditions": ["Positive QBI exists first", "Exclude if Schedule C net ≤ 0 and no other pass-through profit"] },
    { "strategy_id": "ita_030", "title": "Startup Cost Amortization", "category": "business", "covered_by": "none", "inputs_required": ["startup_costs"], "outputs_used": [] },
    { "strategy_id": "ita_031", "title": "Startup Expense Deduction", "category": "business", "covered_by": "none", "inputs_required": ["startup_costs"], "outputs_used": [] },
    { "strategy_id": "ita_033", "title": "401(k) Age 60+ Catch-Up", "category": "retirement", "covered_by": "partial", "inputs_required": ["income.wages", "people.taxpayer.age_65_or_older"], "outputs_used": [] },
    { "strategy_id": "ita_034", "title": "401(k) Employee Deferral", "category": "retirement", "covered_by": "full", "inputs_required": ["income.wages"], "outputs_used": [] },
    { "strategy_id": "ita_035", "title": "401(k) Employer Match", "category": "retirement", "covered_by": "full", "inputs_required": ["income.wages"], "outputs_used": [] },
    { "strategy_id": "ita_036", "title": "403(b) Deferral", "category": "retirement", "covered_by": "partial", "inputs_required": ["income.wages"], "outputs_used": [] },
    { "strategy_id": "ita_037", "title": "403(b) Employer Match", "category": "retirement", "covered_by": "partial", "inputs_required": ["income.wages"], "outputs_used": [] },
    { "strategy_id": "ita_039", "title": "Backdoor Roth IRA", "category": "retirement", "covered_by": "partial", "inputs_required": ["income.wages", "income.schedule_c_net"], "outputs_used": ["magi"] },
    { "strategy_id": "ita_040", "title": "Mega Backdoor Roth", "category": "retirement", "covered_by": "partial", "inputs_required": ["income.wages"], "outputs_used": [] },
    { "strategy_id": "ita_041", "title": "Direct Roth IRA", "category": "retirement", "covered_by": "partial", "inputs_required": ["income.wages", "income.schedule_c_net"], "outputs_used": ["magi"] },
    { "strategy_id": "ita_042", "title": "Roth Conversion", "category": "retirement", "covered_by": "none", "inputs_required": ["ira_balances"], "outputs_used": [] },
    { "strategy_id": "ita_043", "title": "SEP-IRA", "category": "retirement", "covered_by": "full", "inputs_required": ["income.schedule_c_net"], "outputs_used": [], "key_conditions": ["Positive net self-employment earnings", "Exclude if Schedule C net ≤ 0 unless other positive SE net"] },
    { "strategy_id": "ita_044", "title": "Solo 401(k)", "category": "retirement", "covered_by": "full", "inputs_required": ["income.schedule_c_net"], "outputs_used": [], "key_conditions": ["Positive net self-employment earnings", "Exclude if Schedule C net ≤ 0 unless other positive SE net"] },
    { "strategy_id": "ita_045", "title": "Traditional IRA", "category": "retirement", "covered_by": "full", "inputs_required": ["income.wages", "income.schedule_c_net"], "outputs_used": ["magi"] },
    { "strategy_id": "ita_046", "title": "R&D Tax Credit", "category": "credits", "covered_by": "none", "inputs_required": ["rd_expenses"], "outputs_used": [] },
    { "strategy_id": "ita_047", "title": "Child Tax Credit", "category": "credits", "covered_by": "none", "inputs_required": ["people.dependents", "people.dependents.qualifying_child_under_17"], "outputs_used": ["magi"] },
    { "strategy_id": "ita_048", "title": "Residential Energy Credits", "category": "credits", "covered_by": "none", "inputs_required": ["home_improvements"], "outputs_used": [] },
    { "strategy_id": "ita_049", "title": "Donate Appreciated Securities", "category": "charitable", "covered_by": "none", "inputs_required": ["income.long_term_capital_gains", "investment_holdings"], "outputs_used": [] },
    { "strategy_id": "ita_050", "title": "Donor-Advised Fund", "category": "charitable", "covered_by": "partial", "inputs_required": ["income.wages", "income.schedule_c_net"], "outputs_used": [] },
    { "strategy_id": "ita_051", "title": "IRA QCD", "category": "charitable", "covered_by": "none", "inputs_required": ["people.taxpayer.age_70_5_or_older", "ira_balances"], "outputs_used": [] }
