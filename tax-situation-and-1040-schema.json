{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tax situation and Form 1040 calculated lines",
  "description": "Minimal data model for (1) tax situation extracted from raw text by LLM and (2) Form 1040 calculated lines to display. No tax engine codes; human-readable keys only.",
  "type": "object",
  "properties": {
    "tax_situation": {
      "type": "object",
      "description": "Facts from the scenario: filing status, year, people, income, deductions, payments. To be filled by LLM from raw text.",
      "properties": {
        "tax_year": {
          "type": "integer",
          "description": "Tax year (e.g. 2024, 2025)."
        },
        "filing_status": {
          "type": "string",
          "description": "Filing status: Single, Married Filing Jointly, Married Filing Separately, Head of Household, Qualifying Surviving Spouse."
        },
        "primary_taxpayer": {
          "type": "object",
          "description": "Primary filer (and spouse if MFJ).",
          "properties": {
            "first_name": { "type": "string", "description": "First name." },
            "last_name": { "type": "string", "description": "Last name." },
            "date_of_birth": { "type": "string", "description": "Date of birth if given (e.g. 01/01/1984)." },
            "age_65_or_older": { "type": "boolean", "description": "True if scenario says filer is 65 or older." },
            "blind": { "type": "boolean", "description": "True if scenario says filer is blind." }
          }
        },
        "spouse": {
          "type": ["object", "null"],
          "description": "Spouse info if Married Filing Jointly (or similar); null if Single or Head of Household.",
          "properties": {
            "first_name": { "type": "string" },
            "last_name": { "type": "string" },
            "date_of_birth": { "type": "string" },
            "age_65_or_older": { "type": "boolean" },
            "blind": { "type": "boolean" }
          }
        },
        "dependents": {
          "type": "array",
          "description": "List of dependents from the scenario. Retain as array.",
          "items": {
            "type": "object",
            "properties": {
              "first_name": { "type": "string", "description": "Dependent first name." },
              "last_name": { "type": "string", "description": "Dependent last name." },
              "relationship": { "type": "string", "description": "e.g. Daughter, Son, Sister." },
              "date_of_birth_or_age": { "type": "string", "description": "Age or DOB as stated (e.g. 16, or 01/01/2020)." },
              "qualifying_child_under_17": { "type": "boolean", "description": "True if qualifying child under 17 for Child Tax Credit." },
              "claimed": { "type": "boolean", "description": "True if claimed as dependent on return." }
            }
          }
        },
        "income": {
          "type": "object",
          "description": "Income items from scenario. Amounts in dollars (numbers).",
          "properties": {
            "wages": { "type": "number", "description": "W-2 wages." },
            "wages_withholding": { "type": "number", "description": "Federal withholding from wages." },
            "schedule_c_gross_receipts": { "type": "number", "description": "Schedule C gross receipts/sales." },
            "schedule_c_expenses": { "type": "number", "description": "Schedule C total expenses (before depreciation)." },
            "schedule_c_depreciation": { "type": "number", "description": "Schedule C depreciation expense if given." },
            "schedule_c_material_participation": { "type": "boolean", "description": "True if scenario says material participation." },
            "schedule_c_qbi_qualifies": { "type": "boolean", "description": "True if business qualifies for QBI deduction." },
            "ordinary_dividends": { "type": "number", "description": "Ordinary dividends." },
            "qualified_dividends": { "type": "number", "description": "Qualified dividends (subset of ordinary)." },
            "dividend_withholding": { "type": "number", "description": "Withholding on dividends if given." },
            "taxable_interest": { "type": "number", "description": "Taxable interest income." },
            "taxable_pensions": { "type": "number", "description": "Taxable pension income." },
            "short_term_capital_gain_loss": { "type": "number", "description": "Net short-term capital gain or loss (negative if loss) before wash sale adjustment." },
            "wash_sale_disallowed": { "type": "number", "description": "Amount of capital loss disallowed due to wash sale rules." },
            "long_term_capital_gains": { "type": "number", "description": "Net long-term capital gains." },
            "rental_income": { "type": "number", "description": "Rental income or loss (negative if loss)." },
            "other_income": { "type": "number", "description": "Other income from scenario." },
            "depreciable_assets": {
              "type": "array",
              "description": "Depreciable assets placed in service (basis, recovery period, year). Used for bonus depreciation, Section 179 strategies.",
              "items": {
                "type": "object",
                "properties": {
                  "basis": { "type": "number", "description": "Cost basis of the asset." },
                  "recovery_period_years": { "type": "number", "description": "e.g. 7 for 7-year property." },
                  "placed_in_service_year": { "type": "integer", "description": "Tax year placed in service (e.g. 2024)." }
                }
              }
            }
          }
        },
        "itemized_deductions": {
          "type": "object",
          "description": "Itemized deduction components from scenario. SALT cap $10,000 for 2024.",
          "properties": {
            "state_and_local_taxes": { "type": "number", "description": "SALT deductible amount (capped at $10,000 for 2024)." },
            "state_and_local_taxes_paid": { "type": "number", "description": "Total SALT actually paid before cap (for bunching strategies)." },
            "real_estate_taxes": { "type": "number", "description": "Real estate taxes (often part of SALT)." },
            "mortgage_interest": { "type": "number", "description": "Qualified home mortgage interest." },
            "charitable_contributions": { "type": "number", "description": "Cash or other charitable contributions." },
            "medical_expenses": { "type": "number", "description": "Medical if given." }
          }
        },
        "credits_mentioned": {
          "type": "array",
          "description": "Credits stated in scenario (name and amount). Retain as array.",
          "items": {
            "type": "object",
            "properties": {
              "credit_name": { "type": "string", "description": "e.g. Child Tax Credit, Foreign tax credit, Energy credit." },
              "amount": { "type": "number", "description": "Amount if given." }
            }
          }
        },
        "payments": {
          "type": "object",
          "properties": {
            "total_withholding": { "type": "number", "description": "Total federal withholding from scenario." },
            "estimated_tax_payments": { "type": "number", "description": "Estimated tax paid if given." },
            "other_payments": { "type": "number", "description": "Other payments if given." }
          }
        }
      }
    },
    "form_1040_calculated_lines": {
      "type": "object",
      "description": "Calculated amounts to show on 1040-style summary (from LLM or calculator).",
      "properties": {
        "adjusted_gross_income": { "type": "number", "description": "AGI." },
        "magi": { "type": "number", "description": "Modified AGI when different from AGI (for NIIT, CTC phaseouts)." },
        "schedule_c_net_profit_or_loss": { "type": "number", "description": "Schedule C bottom line (positive = profit, negative = loss) that feeds into AGI." },
        "standard_or_itemized_deduction_used": { "type": "string", "description": "e.g. standard or itemized." },
        "deduction_amount": { "type": "number", "description": "Deduction amount used." },
        "qbi_deduction": { "type": "number", "description": "QBI deduction if any." },
        "taxable_income": { "type": "number", "description": "Taxable income." },
        "ordinary_income_portion": { "type": "number", "description": "Portion of taxable income that is ordinary (before preferential)." },
        "preferential_income_portion": { "type": "number", "description": "Portion of taxable income that is LTCG/qualified dividends." },
        "net_investment_income": { "type": "number", "description": "NII for NIIT calculation." },
        "tax_on_ordinary_income": { "type": "number", "description": "Tax on ordinary portion only." },
        "tax_on_preferential_income": { "type": "number", "description": "Tax on LTCG/qualified dividends." },
        "regular_income_tax": { "type": "number", "description": "Regular tax before credits." },
        "net_investment_income_tax": { "type": "number", "description": "NIIT (3.8%)." },
        "tax_before_credits": { "type": "number", "description": "Regular tax + NIIT." },
        "credits_nonrefundable": { "type": "number", "description": "Total nonrefundable credits." },
        "tax_after_credits": { "type": "number", "description": "Tax after nonrefundable credits." },
        "self_employment_tax": { "type": "number", "description": "SE tax." },
        "additional_medicare_tax": { "type": "number", "description": "0.9% additional Medicare tax if any." },
        "other_taxes": { "type": "number", "description": "Other taxes (SE, additional Medicare, etc.)." },
        "total_tax_liability": { "type": "number", "description": "Total tax." },
        "total_payments": { "type": "number", "description": "Withholding + estimated + other." },
        "refundable_credits": { "type": "number", "description": "Refundable credits." },
        "amount_owed_or_refund": { "type": "number", "description": "Positive = owed, negative = refund." }
      }
    }
  },
  "additionalProperties": false
}
